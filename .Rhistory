library(brms)
library(dplyr)
library(readr)
long_df <- read_csv("data/processed/matches_model.csv", show_col_types = FALSE)
priors <- c(
prior(normal(0.3, 0.5), class = "Intercept"),
prior(normal(0.2, 0.3), class = "b",  coef = "es_local"),
prior(normal(0,   0.3), class = "sd")
)
# Prueba: 2 cadenas, 300 iteraciones (~2-3 min)
fit_test <- brm(
goles ~ 1 + es_local + (1 | equipo) + (1 | rival),
data    = long_df,
family  = poisson(link = "log"),
prior   = priors,
weights = peso,
chains  = 2,
iter    = 300,
warmup  = 150,
cores   = 2,
seed    = 42,
refresh = 50,
silent  = 0
# sin file= para no contaminar los outputs oficiales
)
summary(fit_test)
max(rhat(fit_test), na.rm = TRUE)
long_df <- read_csv("data/processed/matches_model.csv", show_col_types = FALSE)
