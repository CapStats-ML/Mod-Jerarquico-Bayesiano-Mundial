bf(goles | weights(peso) ~ 1 + es_local + (1 | equipo) + (1 | rival)),
data    = long_df,
family  = poisson(link = "log"),
prior   = priors,
chains  = 2,
iter    = 300,
warmup  = 150,
cores   = 2,
seed    = 42,
refresh = 50,
silent  = 0
)
